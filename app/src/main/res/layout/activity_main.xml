<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/navy" android:fillViewport="true" android:clipToPadding="false">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingStart="14dp" android:paddingEnd="14dp"
        android:paddingTop="18dp" android:paddingBottom="28dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:padding="4dp">
            <ImageView android:layout_width="56dp" android:layout_height="56dp"
                android:src="@drawable/ic_launcher_foreground" android:contentDescription="Polar WiZ HR icon" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:layout_marginStart="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Polar WiZ HR" android:textColor="@color/text_primary" android:textSize="26sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Live physiology • local lighting" android:textColor="@color/text_secondary" android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout style="@style/CardPanel">
            <TextView style="@style/SectionTitle" android:text="♥  Polar H10" android:textColor="@color/heart" />
            <LinearLayout style="@style/ButtonRow">
                <Button android:id="@+id/scanPolarButton" style="@style/PrimaryButton" android:text="Scan" />
                <Button android:id="@+id/disconnectPolarButton" style="@style/ActionButton" android:text="Disconnect" />
            </LinearLayout>
            <TextView android:id="@+id/polarStatusText" style="@style/BodyText" android:text="Disconnected" />
            <LinearLayout android:id="@+id/polarDeviceList" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
            <TextView android:id="@+id/bpmText" style="@style/MetricText" android:text="-- BPM" />
            <TextView android:id="@+id/smoothedBpmText" style="@style/BodyText" android:text="Smoothed: --   RR: --" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/demoSwitch"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Demo BPM simulation" android:textColor="@color/text_primary" />
        </LinearLayout>

        <LinearLayout style="@style/CardPanel">
            <TextView style="@style/SectionTitle" android:text="✦  WiZ lights" android:textColor="@color/telemetry" />
            <Button android:id="@+id/discoverWizButton" style="@style/PrimaryButton"
                android:layout_width="match_parent" android:layout_weight="0" android:text="Discover lights" />
            <LinearLayout style="@style/ButtonRow">
                <EditText android:id="@+id/manualIpText" android:layout_width="0dp" android:layout_height="48dp"
                    android:layout_weight="2" android:hint="Manual WiZ IP" android:inputType="text"
                    android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary"
                    android:backgroundTint="@color/outline" android:paddingHorizontal="10dp" />
                <Button android:id="@+id/addIpButton" style="@style/ActionButton" android:text="Add IP" />
            </LinearLayout>
            <TextView android:id="@+id/wizStatusText" style="@style/BodyText" android:text="No lights discovered" />
            <LinearLayout android:id="@+id/wizLightList" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
            <TextView style="@style/BodyText" android:text="Manual brightness" />
            <SeekBar android:id="@+id/brightnessSeek" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="60" />
            <LinearLayout style="@style/ButtonRow">
                <Button android:id="@+id/warmButton" style="@style/ActionButton" android:text="Warm" />
                <Button android:id="@+id/violetButton" style="@style/ActionButton" android:text="Purple" />
                <Button android:id="@+id/redButton" style="@style/ActionButton" android:text="Red" />
                <Button android:id="@+id/offButton" style="@style/ActionButton" android:text="Off" android:textColor="#FFFCA5A5" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout style="@style/CardPanel">
            <TextView style="@style/SectionTitle" android:text="⚡  Automation" android:textColor="@color/accent" />
            <TextView style="@style/BodyText" android:text="Lighting theme" />
            <Spinner android:id="@+id/themeSpinner" android:layout_width="match_parent" android:layout_height="48dp"
                android:popupBackground="@color/panel_variant" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/automationSwitch"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Enable HR-controlled lighting" android:textColor="@color/text_primary" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/heartbeatPulseSwitch"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Subtle heartbeat pulse" android:textColor="@color/text_primary" />
            <TextView android:id="@+id/zoneText" style="@style/MetricText" android:text="Zone: --" />
            <TextView android:id="@+id/lastCommandText" style="@style/BodyText" android:text="Last command: none" android:maxLines="3" android:ellipsize="end" />
            <TextView android:id="@+id/errorText" style="@style/BodyText" android:textColor="#FFFCA5A5" android:maxLines="3" android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
